<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.ui.DetailDrawerController" style="-fx-padding:12;">
    <VBox spacing="12" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="Details" styleClass="card-title" />
            <Pane HBox.hgrow="ALWAYS" />
            <Button text="Close" onAction="#onClose" />
        </HBox>
        <Separator />
        <VBox fx:id="contentArea" spacing="8">
            <!-- populated by controller -->
            <Label fx:id="lblProduct" text="Product" styleClass="info-label" />
            <Label fx:id="lblExpiry" text="Expiry" />
            <ProgressBar fx:id="warrantyProgress" prefWidth="300" />
        </VBox>
    </VBox>
</AnchorPane>
